{
	"name": "choctaw-nation/advanced-technology",
	"description": "a block theme for the CNOAA (ATI) site",
	"type": "project",
	"version": "1.1.0",
	"autoload": {
		"classmap": [
			"inc/"
		]
	},
	"repositories": [
		{
			"type": "composer",
			"url": "https://wpackagist.org",
			"only": [
				"wpackagist-plugin/*",
				"wpackagist-theme/*"
			]
		}
	],
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"phpcs": "phpcs . --extensions=php --ignore=dist/",
		"phpcbf": "phpcbf . --extensions=php --ignore=dist/"
	},
	"require-dev": {
		"wp-coding-standards/wpcs": "*"
	}
}
